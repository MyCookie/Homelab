# define a named match for caddy to filter
@nextcloudlogin path /login* /login/*

{$DOMAIN_URL} {
    # for synapse
    header /.well-known/matrix/* Content-Type application/json
    header /.well-known/matrix/* Access-Control-Allow-Origin *
    respond /.well-known/matrix/server `{"m.server": "matrix.{$DOMAIN_URL}:443"}`
    respond /.well-known/matrix/client `{"m.homeserver":{"base_url":"https://matrix.{$DOMAIN_URL}"}}`

    respond 200 "Hello, World!"
}

cloud.{$DOMAIN_URL} {
    # we don't want anyone logging in from outside the tailnet
    respond @nextcloudlogin 403

    reverse_proxy https://nextcloud.{$TAILNET}.ts.net
}

matrix.{$DOMAIN_URL} {
    reverse_proxy /_matrix/* https://nextcloud.{$TAILNET}.ts.net:8008
    reverse_proxy /_synapse/client/* https://nextcloud.{$TAILNET}.ts.net:8008
}
